# =============================================================================
# LIBRA environment configuration
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# ---- Backend (FastAPI) -----------------------------------------------------
LIBRA_ENV=development
LIBRA_API_HOST=0.0.0.0
LIBRA_API_PORT=8000
LIBRA_LOG_LEVEL=info

# CORS origins the API accepts (comma-separated). The Next.js dev server
# usually runs on http://localhost:3000.
LIBRA_CORS_ORIGINS=http://localhost:3000

# ---- OpenAI Realtime provider ---------------------------------------------
# Server-side only. Never expose this to the browser.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy

# ---- ElevenLabs + OpenAI provider ----------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Lowest-latency model. Other options: eleven_turbo_v2_5, eleven_multilingual_v2.
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
OPENAI_REASONING_MODEL=gpt-4.1-mini
# Streaming STT model used in transcription-only mode of the Realtime API.
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper

# ---- Memory (v0.2) --------------------------------------------------------
# Embedding model for long-term memory. 1536-dim matches the schema.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LIBRA_EMBEDDING_DIM=1536
LIBRA_MEMORY_SHORT_TERM_MAX_TURNS=40
LIBRA_MEMORY_RECALL_TOP_K=5
LIBRA_MEMORY_DEFAULT_USER_ID=default
# Model used by the end-of-session distiller to extract facts.
LIBRA_MEMORY_DISTILL_MODEL=gpt-4.1-mini

# ---- Tools (v0.3) ---------------------------------------------------------
# Master switch. When false, the assistant runs without any tools (pure text).
LIBRA_TOOLS_ENABLED=true
# Hard cap on tool-loop rounds per user turn. Prevents runaway calls.
LIBRA_TOOLS_MAX_ITERATIONS=5
# Enable OpenAI's built-in web_search hosted tool in Responses API calls.
LIBRA_WEB_SEARCH_ENABLED=true

# ---- Spotify integration (v0.3) -------------------------------------------
# Register an app at https://developer.spotify.com/dashboard.
# Redirect URI must match exactly. Spotify rejects "localhost" for new apps;
# use the 127.0.0.1 form below.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/spotify/auth/callback
# Where to bounce the browser after a successful OAuth callback.
SPOTIFY_POST_AUTH_REDIRECT=http://localhost:3000/?spotify=connected

# Public WebSocket base the browser uses to reach the backend for the
# ElevenLabs + OpenAI pipeline. Defaults to ws://localhost:8000 if unset.
NEXT_PUBLIC_API_WS_BASE_URL=ws://localhost:8000

# ---- Database -------------------------------------------------------------
POSTGRES_USER=libra
POSTGRES_PASSWORD=libra
POSTGRES_DB=libra
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://libra:libra@postgres:5432/libra

# ---- Redis ----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- MQTT / Vision (v0.4) -------------------------------------------------
# The API subscribes to vision events here. Hostname is the docker service
# name when the API runs in compose; switch to a LAN IP / hostname when
# remote devices (Jetson, Pi) need to reach the broker.
LIBRA_MQTT_HOST=mosquitto
LIBRA_MQTT_PORT=1883
LIBRA_MQTT_USERNAME=
LIBRA_MQTT_PASSWORD=
# MQTT topic patterns the brain listens to. "+" matches one segment.
LIBRA_VISION_TOPIC_FILTER=libra/vision/+/detections
LIBRA_VISION_STATUS_TOPIC_FILTER=libra/vision/+/status
# Master switch — set false to disable the vision bridge entirely.
LIBRA_VISION_ENABLED=true

# ---- Frontend (Next.js) ---------------------------------------------------
# Public-safe values only. Browser must never see provider API keys.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_VOICE_PROVIDER=openai-realtime
