# ---- Identity ---------------------------------------------------------------
# Logical name for this camera/source. Used as the topic suffix:
#   libra/vision/{source_id}/detections
# Make it unique per device, e.g. "mac-webcam", "jetson-cam-1".
LIBRA_VISION_SOURCE_ID=mac-webcam

# ---- Camera -----------------------------------------------------------------
# Integer (cv2.VideoCapture index) or RTSP/HTTP URL, or a file path for testing.
# Mac built-in webcam is usually 0.
LIBRA_VISION_CAMERA=0
LIBRA_VISION_FRAME_WIDTH=640
LIBRA_VISION_FRAME_HEIGHT=480
# Process every Nth frame. 1 = every frame. Higher = less CPU/GPU.
LIBRA_VISION_FRAME_STRIDE=2

# ---- Model ------------------------------------------------------------------
# Ultralytics model name or path. yolov8n is the fastest/smallest;
# step up to yolov8s for slightly better accuracy if you have headroom.
LIBRA_VISION_MODEL=yolov8n.pt
# Detection confidence threshold.
LIBRA_VISION_CONFIDENCE=0.45
# Compute device. Leave blank for auto (mps on mac silicon, cuda on jetson, cpu fallback).
# Override with "cpu" / "mps" / "cuda" / "cuda:0" to pin.
LIBRA_VISION_DEVICE=

# ---- Class filter -----------------------------------------------------------
# Comma-separated COCO class names. v0 ships person-only to keep signal high.
# Empty = no filter (all 80 classes).
LIBRA_VISION_CLASSES=person

# ---- Event policy -----------------------------------------------------------
# "on_change" — emit only when the set of detected classes changes.
# "throttled" — emit every N seconds.
# "both"      — heartbeat + change.
LIBRA_VISION_POLICY=on_change
LIBRA_VISION_HEARTBEAT_SECONDS=10

# ---- MQTT -------------------------------------------------------------------
# Broker for event publication. From the Jetson, point at the Mac's LAN IP.
LIBRA_VISION_MQTT_HOST=127.0.0.1
LIBRA_VISION_MQTT_PORT=1883
# Empty for anonymous (default dev setup). Set both for auth.
LIBRA_VISION_MQTT_USERNAME=
LIBRA_VISION_MQTT_PASSWORD=
# Topic prefix; events go to {prefix}/{source_id}/detections.
LIBRA_VISION_MQTT_TOPIC_PREFIX=libra/vision
# QoS 0 fire-and-forget; 1 at-least-once; 2 exactly-once.
LIBRA_VISION_MQTT_QOS=1
